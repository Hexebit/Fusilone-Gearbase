<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Fusilone Light Theme Tokens -->

    <!-- Base Colors -->
    <SolidColorBrush x:Key="FslBgBase" Color="#EDE6DA" />
    <SolidColorBrush x:Key="FslSurface" Color="#F7F2E9" />
    <SolidColorBrush x:Key="FslSurface2" Color="#FDFBF6" />
    <SolidColorBrush x:Key="FslBorder" Color="#D9D1C1" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="FslTextPrimary" Color="#17181C" />
    <SolidColorBrush x:Key="FslTextSecondary" Color="#6B665C" />
    <SolidColorBrush x:Key="FslTextDisabled" Color="#A19B8D" />

    <!-- Accent & Status -->
    <SolidColorBrush x:Key="FslAccent" Color="#12857C" />
    <SolidColorBrush x:Key="FslAccentFaint" Color="#1A12857C" />
    <SolidColorBrush x:Key="FslAccentHover" Color="#0F6E67" />
    <SolidColorBrush x:Key="FslAccentPressed" Color="#0B5A54" />
    <SolidColorBrush x:Key="FslOnAccent" Color="#F2FBFA" />
    <SolidColorBrush x:Key="FslSuccess" Color="#1B8A49" />
    <SolidColorBrush x:Key="FslSuccessFaint" Color="#241B8A49" />
    <SolidColorBrush x:Key="FslDanger" Color="#C22F24" />
    <SolidColorBrush x:Key="FslDangerFaint" Color="#1FC22F24" />
    <SolidColorBrush x:Key="FslDisabledFaint" Color="#24A19B8D" />

    <!-- Legacy bridge: eski key'leri kullanan görünümler (KanbanView, DeviceDetailWindow) için Fusilone paletine eşleme -->
    <SolidColorBrush x:Key="SuccessColor" Color="#1B8A49" />
    <SolidColorBrush x:Key="ErrorColor" Color="#C22F24" />
    <SolidColorBrush x:Key="AccentColor" Color="#12857C" />
    <SolidColorBrush x:Key="StatusColor_Pending" Color="#0F6E67" />
    <SolidColorBrush x:Key="StatusColor_InProgress" Color="#12857C" />
    <SolidColorBrush x:Key="StatusColor_Ready" Color="#1B8A49" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#26D9D1C1" />
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="#FDFBF6" />

    <!-- Material Design v5.x Bridge: Override MDIX brushes with Fusilone tokens -->
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary" Color="#12857C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Light" Color="#0F6E67" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Dark" Color="#0B5A54" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary" Color="#6B665C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary.Light" Color="#6B665C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary.Dark" Color="#6B665C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Tertiary" Color="#12857C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Tertiary.Light" Color="#0F6E67" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Tertiary.Dark" Color="#0B5A54" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Background" Color="#EDE6DA" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Surface" Color="#F7F2E9" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.SurfaceVariant" Color="#FDFBF6" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Foreground" Color="#17181C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnSurface" Color="#17181C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnSurfaceVariant" Color="#6B665C" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Outline" Color="#D9D1C1" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Error" Color="#C22F24" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.ErrorContainer" Color="#F9DEDB" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnError" Color="#FFFFFF" />

</ResourceDictionary>
