<Application x:Class="Fusilone.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Fusilone"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dark Mode Color Overrides for Better Contrast -->
            <SolidColorBrush x:Key="MaterialDesignPaper" Color="#121212"/>
            <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="MaterialDesignBody" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#CE93D8"/>
            <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#E1BEE7"/>
            <SolidColorBrush x:Key="SecondaryHueMidBrush" Color="#CDDC39"/>
            <SolidColorBrush x:Key="MaterialDesignDivider" Color="#404040"/>

            <!-- Status and Type Colors -->
            <SolidColorBrush x:Key="SuccessColor" Color="#81C784"/>
            <SolidColorBrush x:Key="ErrorColor" Color="#EF5350"/>
            <SolidColorBrush x:Key="AccentColor" Color="#FFD54F"/>
            <SolidColorBrush x:Key="TypeColor_PC" Color="#64B5F6"/>
            <SolidColorBrush x:Key="TypeColor_LP" Color="#FFB74D"/>
            <SolidColorBrush x:Key="TypeColor_AO" Color="#BA68C8"/>
            <SolidColorBrush x:Key="TypeColor_PH" Color="#29B6F6"/>
            <SolidColorBrush x:Key="TypeColor_ET" Color="#EF5350"/>
            <SolidColorBrush x:Key="TypeColor_MN" Color="#9CCC65"/>
            <SolidColorBrush x:Key="StatusColor_Pending" Color="#42A5F5"/>
            <SolidColorBrush x:Key="StatusColor_InProgress" Color="#FFA726"/>
            <SolidColorBrush x:Key="StatusColor_Ready" Color="#66BB6A"/>
            <SolidColorBrush x:Key="OverlayBrush" Color="#33222222"/>
            <SolidColorBrush x:Key="ItemBackgroundBrush" Color="#2A2A2A"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            </Style>
            <Style TargetType="materialDesign:Card">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>