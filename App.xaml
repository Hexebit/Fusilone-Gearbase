<Application x:Class="Fusilone.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Fusilone"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design v5.x with Teal as primary -->
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Teal" SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <!-- Fusilone tokens overlay -->
                <ResourceDictionary Source="pack://application:,,,/Fusilone;component/Themes/Fusilone.Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Fusilone logo mark: resmi FGB logosu (assets/logo.png), tüm kullanım noktaları bu stili paylaşır -->
            <Style x:Key="FslLogoMark" TargetType="Control">
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Control">
                            <Image Source="pack://application:,,,/assets/logo.png"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Fusilone font tokens (Adım: Tipografi'de embed edilecek; şimdilik sistem fallback) -->
            <FontFamily x:Key="FslFontMono">Consolas</FontFamily>

            <!-- Fusilone tek input stili: Outlined varyant, FslSurface2 zemin, FslAccent focus, 8px radius -->
            <Style x:Key="FslTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Background" Value="{DynamicResource FslSurface2}"/>
                <Setter Property="Foreground" Value="{DynamicResource FslTextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource FslTextSecondary}"/>
                <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8"/>
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness" Value="1.5"/>
            </Style>

            <Style x:Key="FslComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="Background" Value="{DynamicResource FslSurface2}"/>
                <Setter Property="Foreground" Value="{DynamicResource FslTextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource FslTextSecondary}"/>
                <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8"/>
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness" Value="1.5"/>
            </Style>

            <Style x:Key="FslDatePicker" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
                <Setter Property="Background" Value="{DynamicResource FslSurface2}"/>
                <Setter Property="Foreground" Value="{DynamicResource FslTextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource FslTextSecondary}"/>
                <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8"/>
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness" Value="1.5"/>
            </Style>

            <!-- Primary buton: FslAccent zemin, FslOnAccent yazı, 8px radius, hover FslAccentHover -->
            <Style x:Key="FslPrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{DynamicResource FslAccent}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslAccent}"/>
                <Setter Property="Foreground" Value="{DynamicResource FslOnAccent}"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource FslAccentHover}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource FslAccentHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource FslAccentPressed}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource FslAccentPressed}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secondary buton: transparan zemin, 1px FslBorder, FslTextPrimary yazı, hover FslSurface2 -->
            <Style x:Key="FslSecondaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}"/>
                <Setter Property="Foreground" Value="{DynamicResource FslTextPrimary}"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource FslSurface2}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Destructive buton: FslDanger zemin -->
            <Style x:Key="FslDangerButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{DynamicResource FslDanger}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource FslDanger}"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            </Style>

            <!-- Tablo başlıkları: 11.5, ikincil renk -->
            <Style x:Key="FslColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                <Setter Property="Foreground" Value="{DynamicResource FslTextSecondary}"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- Tablo satırı: hover FslSurface2, 1px alt ayraç -->
            <Style x:Key="FslDataGridRow" TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource FslSurface2}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Card style: 8px radius, 1px border, no shadow -->
            <Style TargetType="materialDesign:Card">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
                <Setter Property="UniformCornerRadius" Value="8" />
                <Setter Property="BorderBrush" Value="{DynamicResource FslBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource FslSurface}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
