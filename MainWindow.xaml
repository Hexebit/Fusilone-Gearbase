<Window x:Class="Fusilone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fusilone"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:converters="clr-namespace:Fusilone.Converters"
        xmlns:views="clr-namespace:Fusilone.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" Height="780" Width="1200" MinHeight="600" MinWidth="900"
        Icon="pack://application:,,,/assets/logo.png"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource FslBgBase}"
        TextElement.Foreground="{DynamicResource FslTextPrimary}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">
    
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="5" GlassFrameThickness="1" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:DateConverter x:Key="DateConverter"/>
        <converters:StatusDisplayConverter x:Key="StatusDisplayConverter"/>

        <!-- Sidebar nav item: default FslTextSecondary, hover FslSurface2, seçili: 3px accent bar + FslAccentFaint zemin -->
        <Style x:Key="FslNavItem" TargetType="RadioButton">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource FslTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bg" Background="Transparent"/>
                            <Border x:Name="AccentBar" Width="3" HorizontalAlignment="Left" Background="{DynamicResource FslAccent}" Visibility="Collapsed"/>
                            <ContentPresenter Margin="20,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource FslSurface2}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource FslAccentFaint}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FslTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainRootBorder" Background="{DynamicResource FslBgBase}" CornerRadius="0" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Standart Navigasyon -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title Bar (36px) -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource FslBgBase}" Height="36">
                <!-- Sol: Logo + Başlık -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Control Style="{StaticResource FslLogoMark}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Fusilone Gearbase" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource FslTextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Sağ: Min/Max/Close Butonları -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Name="MinButton" Click="MinButton_Click" Style="{DynamicResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0" ToolTip="Minimize">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" Foreground="{DynamicResource FslTextSecondary}"/>
                    </Button>
                    <Button Name="MaxButton" Click="MaxButton_Click" Style="{DynamicResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0" ToolTip="Maximize">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" Foreground="{DynamicResource FslTextSecondary}"/>
                    </Button>
                    <Button Name="CloseButton" Click="TitleBarClose_Click" Style="{DynamicResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0" ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="{DynamicResource FslDanger}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Sol Sütun: Standart Menü -->
            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource FslSurface}" BorderBrush="{DynamicResource FslBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,20,0,0">
                        <Control Style="{StaticResource FslLogoMark}" Width="96" Height="96"
                                 HorizontalAlignment="Center" Margin="0,10,0,14"/>

                        <TextBlock Text="FUSILONE GEARBASE" FontSize="22" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="{DynamicResource FslTextPrimary}"/>
                        <TextBlock Text="{DynamicResource AppSubtitle}" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="{DynamicResource FslTextSecondary}" FontWeight="SemiBold"/>

                        <RadioButton x:Name="NavDashboard" GroupName="MainNav" Style="{StaticResource FslNavItem}" Click="ShowList_Click" IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,14,0" VerticalAlignment="Center" Width="22" Height="22"/>
                                <TextBlock Text="{DynamicResource Menu_Dashboard}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavSearch" GroupName="MainNav" Style="{StaticResource FslNavItem}" Click="ShowSearch_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Margin="0,0,14,0" VerticalAlignment="Center" Width="22" Height="22"/>
                                <TextBlock Text="{DynamicResource Menu_DeviceSearch}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavAdd" GroupName="MainNav" Style="{StaticResource FslNavItem}" Click="ShowAdd_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0,0,14,0" VerticalAlignment="Center" Width="22" Height="22"/>
                                <TextBlock Text="{DynamicResource Menu_AddDevice}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavMaintenance" GroupName="MainNav" Style="{StaticResource FslNavItem}" Click="MaintenanceButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Margin="0,0,14,0" VerticalAlignment="Center" Width="22" Height="22"/>
                                <TextBlock Text="{DynamicResource Menu_Maintenance}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavCustomers" GroupName="MainNav" Style="{StaticResource FslNavItem}" Click="ShowCustomers_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Margin="0,0,14,0" VerticalAlignment="Center" Width="22" Height="22"/>
                                <TextBlock Text="{DynamicResource Menu_Customers}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10">
                        <Button Style="{DynamicResource MaterialDesignFlatButton}" Click="ShowAbout_Click" HorizontalAlignment="Center" Foreground="{DynamicResource FslTextSecondary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="InformationOutline" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Menu_About}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{DynamicResource VersionLabel}" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource FslTextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sağ Sütun: Ana İçerik -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/> <!-- Top Bar -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" Background="{DynamicResource FslSurface}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                        <TextBlock Text="FUSILONE GEARBASE" FontSize="18" FontWeight="Black" Foreground="{DynamicResource FslTextPrimary}"/>
                        <TextBlock Text=" | " Foreground="{DynamicResource FslTextDisabled}" Margin="10,0"/>
                        <TextBlock x:Name="ViewTitle" Text="{DynamicResource View_Dashboard}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource FslAccent}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="25,0">
                        <materialDesign:PopupBox Style="{DynamicResource MaterialDesignPopupBox}"
                                                     PlacementMode="BottomAndAlignRightEdges"
                                                     ToolTip="Ayarlar"
                                                     Margin="0,0,15,0">
                                <materialDesign:PopupBox.ToggleContent>
                                    <materialDesign:PackIcon Kind="Settings" Width="24" Height="24"/>
                                </materialDesign:PopupBox.ToggleContent>
                                <Border Padding="10">
                                    <StackPanel Width="200">
                                        <TextBlock Text="{DynamicResource Settings_Title}" FontWeight="Bold" Margin="10,5,10,15" Foreground="{DynamicResource FslTextSecondary}" FontSize="10"/>
                                        <Grid Margin="10,0,10,10">
                                            <TextBlock Text="{DynamicResource Settings_DarkTheme}" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="ThemeToggle" Style="{DynamicResource MaterialDesignSwitchToggleButton}"
                                                          HorizontalAlignment="Right" Click="ToggleTheme_Click"/>
                                        </Grid>
                                        <Separator Style="{DynamicResource MaterialDesignDarkSeparator}"/>
                                        <Grid Margin="10,10,10,5">
                                            <TextBlock Text="{DynamicResource Settings_Language}" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{DynamicResource MaterialDesignFlatButton}" Content="TR" Padding="4" MinWidth="30" FontSize="10" Click="LangTR_Click"/>
                                                <Button Style="{DynamicResource MaterialDesignFlatButton}" Content="EN" Padding="4" MinWidth="30" FontSize="10" Click="LangEN_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Style="{DynamicResource MaterialDesignDarkSeparator}"/>
                                        <StackPanel Margin="10,10,10,5">
                                            <Button Style="{StaticResource FslPrimaryButton}" Click="BackupButton_Click" Content="{DynamicResource Settings_Backup}"/>
                                            <Button Style="{DynamicResource MaterialDesignFlatButton}" Click="ExportCsv_Click" Content="{DynamicResource Settings_ExportCsv}" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
                                            <Button Style="{DynamicResource MaterialDesignFlatButton}" Click="ExportExcel_Click" Content="{DynamicResource Settings_ExportExcel}" HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </materialDesign:PopupBox>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="25">
                    <!-- 1. GÖRÜNÜM: DASHBOARD -->
                    <materialDesign:TransitioningContent x:Name="DeviceListTransitioner">
                        <Grid x:Name="DeviceListView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- İSTATİSTİK KARTLARI -->
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" Padding="20">
                                    <StackPanel>
                                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource FslSurface2}" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="Monitor" Width="20" Height="20" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource Stat_TotalDevices}" Margin="0,12,0,4" FontSize="11.5" Foreground="{DynamicResource FslTextSecondary}"/>
                                        <TextBlock x:Name="StatTotalCount" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource FslTextPrimary}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Grid.Column="1" Margin="5,0,5,0" Padding="20">
                                    <StackPanel>
                                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource FslSurface2}" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource Stat_Active}" Margin="0,12,0,4" FontSize="11.5" Foreground="{DynamicResource FslTextSecondary}"/>
                                        <TextBlock x:Name="StatActiveCount" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource FslTextPrimary}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Grid.Column="2" Margin="5,0,5,0" Padding="20">
                                    <StackPanel>
                                        <Border x:Name="MaintChip" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource FslSurface2}" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon x:Name="MaintChipIcon" Kind="AlertCircle" Width="20" Height="20" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource Stat_MaintDue}" Margin="0,12,0,4" FontSize="11.5" Foreground="{DynamicResource FslTextSecondary}"/>
                                        <TextBlock x:Name="StatMaintDueCount" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource FslTextPrimary}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Grid.Column="3" Margin="10,0,0,0" Padding="20">
                                    <StackPanel>
                                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource FslSurface2}" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="CurrencyTry" Width="20" Height="20" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource Stat_TotalValue}" Margin="0,12,0,4" FontSize="11.5" Foreground="{DynamicResource FslTextSecondary}"/>
                                        <TextBlock x:Name="StatTotalValue" Text="0 ₺" FontSize="28" FontWeight="SemiBold" FontFamily="{StaticResource FslFontMono}" Foreground="{DynamicResource FslTextPrimary}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </Grid>
                            
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <materialDesign:Card Padding="0" Margin="0,0,15,0" VerticalAlignment="Stretch">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Padding="20,14" BorderBrush="{DynamicResource FslBorder}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <TextBlock Text="{DynamicResource Inventory_List}" Foreground="{DynamicResource FslTextSecondary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <ToggleButton x:Name="KanbanToggle" HorizontalAlignment="Right" Width="32" Height="32"
                                                              Style="{DynamicResource MaterialDesignActionToggleButton}" Click="KanbanToggle_Click"
                                                              Background="{DynamicResource FslSurface2}" Foreground="{DynamicResource FslTextSecondary}">
                                                    <ToggleButton.Content>
                                                        <materialDesign:PackIcon Kind="ViewColumn" Width="16" Height="16"/>
                                                    </ToggleButton.Content>
                                                    <materialDesign:ToggleButtonAssist.OnContent>
                                                        <materialDesign:PackIcon Kind="FormatListBulleted" Width="16" Height="16"/>
                                                    </materialDesign:ToggleButtonAssist.OnContent>
                                                </ToggleButton>
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Row="1">
                                            <DataGrid x:Name="DevicesDataGrid"
                                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                                      materialDesign:DataGridAssist.CellPadding="12 10"
                                                      Background="Transparent" BorderThickness="0"
                                                      ColumnHeaderStyle="{StaticResource FslColumnHeader}"
                                                      RowStyle="{StaticResource FslDataGridRow}"
                                                      MouseDoubleClick="DevicesDataGrid_MouseDoubleClick">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Width="60">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Width="40" Height="40" CornerRadius="8"
                                                                        Background="{DynamicResource FslSurface2}"
                                                                        BorderBrush="{DynamicResource FslBorder}" BorderThickness="1">
                                                                    <Grid>
                                                                        <materialDesign:PackIcon x:Name="FallbackIcon" Kind="Monitor" Width="18" Height="18"
                                                                                                 Foreground="{DynamicResource FslTextSecondary}"
                                                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                 Visibility="Collapsed"/>
                                                                        <Image x:Name="DeviceImage" Source="{Binding ImageUrl}" Stretch="Uniform" Margin="2"/>
                                                                    </Grid>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                                        <Setter TargetName="FallbackIcon" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="DeviceImage" Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                                        <Setter TargetName="FallbackIcon" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="DeviceImage" Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="{DynamicResource Col_Type}" Binding="{Binding Type}" FontWeight="Bold"/>
                                                    <DataGridTextColumn Header="{DynamicResource Col_BrandModel}" Binding="{Binding FullName}" Width="*"/>
                                                    <DataGridTemplateColumn Header="{DynamicResource Col_Status}">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border x:Name="StatusBadge" CornerRadius="10" Padding="10,3" HorizontalAlignment="Left"
                                                                        Background="{DynamicResource FslDisabledFaint}">
                                                                    <TextBlock x:Name="StatusBadgeText" FontSize="11.5" FontWeight="Medium"
                                                                               Foreground="{DynamicResource FslTextDisabled}"
                                                                               Text="{Binding Status, Converter={StaticResource StatusDisplayConverter}}"/>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Aktif">
                                                                        <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource FslSuccessFaint}"/>
                                                                        <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{DynamicResource FslSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Arızalı">
                                                                        <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource FslDangerFaint}"/>
                                                                        <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{DynamicResource FslDanger}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Bakımda">
                                                                        <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource FslAccentFaint}"/>
                                                                        <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{DynamicResource FslAccent}"/>
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="{DynamicResource Col_Owner}" Binding="{Binding OwnerName}" Width="*"/>
                                                    <DataGridTemplateColumn Header="">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Click="DeleteDevice_Click" Tag="{Binding Id}" ToolTip="Sil">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                                            <Setter Property="Foreground" Value="{DynamicResource FslTextSecondary}"/>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource FslDanger}"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                                                </Button>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <views:DeviceKanbanView x:Name="KanbanBoard" Visibility="Collapsed"/>

                                            <!-- Boş durum: hiç cihaz yok -->
                                            <StackPanel x:Name="InventoryEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" Margin="20">
                                                <materialDesign:PackIcon Kind="PackageVariantClosed" Width="52" Height="52" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Empty_Inventory_Title}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" Margin="0,14,0,4"/>
                                                <TextBlock Text="{DynamicResource Empty_Inventory_Desc}" FontSize="12" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320"/>
                                                <Button Style="{StaticResource FslPrimaryButton}" Click="ShowAdd_Click" HorizontalAlignment="Center" Margin="0,18,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{DynamicResource Empty_Inventory_Cta}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <!-- Boş durum: filtre eşleşmesi yok -->
                                            <StackPanel x:Name="InventoryFilteredEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" Margin="20">
                                                <materialDesign:PackIcon Kind="MagnifyClose" Width="52" Height="52" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Empty_Filtered}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource FslTextSecondary}" HorizontalAlignment="Center" Margin="0,14,0,4"/>
                                                <TextBlock Text="{DynamicResource Empty_Filtered_Desc}" FontSize="12" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </materialDesign:Card>
                                
                                <materialDesign:Card Grid.Column="1" Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{DynamicResource Device_Distribution}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource FslTextSecondary}" Margin="0,0,0,10"/>
                                        <lvc:PieChart x:Name="DeviceTypeChart" Grid.Row="1" LegendPosition="Bottom"/>
                                        <StackPanel x:Name="ChartEmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                                            <materialDesign:PackIcon Kind="ChartPie" Width="40" Height="40" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource Chart_NeedTwoCategories}" FontSize="11.5" Foreground="{DynamicResource FslTextSecondary}" Margin="0,10,0,4" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="ChartEmptyDetail" FontSize="11.5" Foreground="{DynamicResource FslTextDisabled}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Grid>
                        </Grid>
                    </materialDesign:TransitioningContent>

                    <!-- 2. GÖRÜNÜM: SORGULAMA -->
                    <materialDesign:TransitioningContent x:Name="SearchTransitioner" Visibility="Collapsed">
                        <Grid x:Name="SearchView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <materialDesign:Card Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SearchBox" materialDesign:HintAssist.Hint="{DynamicResource Search_Hint}" Style="{StaticResource FslTextBox}" Margin="0,0,20,0" TextChanged="SearchBox_TextChanged"/>
                                        <ComboBox x:Name="FilterTypeCombo" Grid.Column="1" Margin="0,0,15,0" materialDesign:HintAssist.Hint="{DynamicResource Filter_Type}" Style="{StaticResource FslComboBox}" SelectionChanged="Filter_SelectionChanged">
                                            <ComboBoxItem Content="{DynamicResource Filter_All}" Tag="ALL" IsSelected="True"/>
                                            <ComboBoxItem Content="AO"/>
                                            <ComboBoxItem Content="PC"/>
                                            <ComboBoxItem Content="LP"/>
                                            <ComboBoxItem Content="ET"/>
                                            <ComboBoxItem Content="GC"/>
                                            <ComboBoxItem Content="MN"/>
                                            <ComboBoxItem Content="PH"/>
                                            <ComboBoxItem Content="TB"/>
                                            <ComboBoxItem Content="PR"/>
                                            <ComboBoxItem Content="RT"/>
                                            <ComboBoxItem Content="PJ"/>
                                        </ComboBox>
                                        <ComboBox x:Name="FilterStatusCombo" Grid.Column="2" materialDesign:HintAssist.Hint="{DynamicResource Filter_Status}" Style="{StaticResource FslComboBox}" SelectionChanged="Filter_SelectionChanged">
                                            <ComboBoxItem Content="{DynamicResource Filter_All}" Tag="ALL" IsSelected="True"/>
                                            <ComboBoxItem Content="{DynamicResource Status_Active}" Tag="Aktif"/>
                                            <ComboBoxItem Content="{DynamicResource Status_Faulty}" Tag="Arızalı"/>
                                        </ComboBox>
                                    </Grid>
                                    <Expander Header="{DynamicResource Filter_Advanced}" Margin="0,15,0,0">
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="SpecKeyBox" materialDesign:HintAssist.Hint="{DynamicResource Filter_SpecKey}" Style="{StaticResource FslTextBox}" Margin="0,0,10,0"/>
                                            <TextBox x:Name="SpecValueBox" Grid.Column="1" materialDesign:HintAssist.Hint="{DynamicResource Filter_SpecValue}" Style="{StaticResource FslTextBox}" TextChanged="SpecFilter_TextChanged"/>
                                        </Grid>
                                    </Expander>
                                </StackPanel>
                            </materialDesign:Card>
                            <materialDesign:Card Grid.Row="1" Padding="0">
                                <DataGrid x:Name="SearchResultsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MouseDoubleClick="DevicesDataGrid_MouseDoubleClick" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{DynamicResource Col_Id}" Binding="{Binding Id}" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_Type}" Binding="{Binding Type}"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_BrandModel}" Binding="{Binding FullName}" Width="*"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_Owner}" Binding="{Binding OwnerName}" Width="*"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_Status}" Binding="{Binding Status, Converter={StaticResource StatusDisplayConverter}}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </materialDesign:Card>
                        </Grid>
                    </materialDesign:TransitioningContent>

                    <!-- 3. GÖRÜNÜM: YENİ CİHAZ EKLEME -->
                    <materialDesign:TransitioningContent x:Name="AddDeviceTransitioner" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                            <materialDesign:Card Padding="30" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource AddForm_Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,25"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="260"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Top">
                                            <Border Width="220" Height="220" Background="{DynamicResource FslSurface2}" BorderBrush="{DynamicResource FslBorder}" BorderThickness="1" CornerRadius="8">
                                                <Grid>
                                                    <materialDesign:PackIcon Kind="Image" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource FslTextDisabled}"/>
                                                    <Image x:Name="PreviewImage" Stretch="UniformToFill" Margin="4"/>
                                                </Grid>
                                            </Border>
                                            <Button Style="{StaticResource FslPrimaryButton}" Margin="0,20,0,0" Width="220" Click="AutoImageSearch_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AutoFix" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{DynamicResource AddForm_FindImage}"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBox x:Name="ImageUrlTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_ImageUrl}" Style="{StaticResource FslTextBox}" Margin="0,15,0,0" TextChanged="ImageUrlTextBox_TextChanged"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1" Margin="30,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <ComboBox x:Name="TypeComboBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Category}" Style="{StaticResource FslComboBox}" Margin="0,0,0,20" SelectionChanged="TypeComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="AO (All-In-One PC)"/>
                                                    <ComboBoxItem Content="PC (Masaüstü Bilgisayar)"/>
                                                    <ComboBoxItem Content="LP (Laptop)"/>
                                                    <ComboBoxItem Content="ET (Akıllı Tahta)"/>
                                                    <ComboBoxItem Content="GC (Oyun Konsolu)"/>
                                                    <ComboBoxItem Content="MN (Monitör)"/>
                                                    <ComboBoxItem Content="PH (Telefon)"/>
                                                    <ComboBoxItem Content="TB (Tablet)"/>
                                                    <ComboBoxItem Content="PR (Yazıcı)"/>
                                                    <ComboBoxItem Content="RT (Router)"/>
                                                    <ComboBoxItem Content="PJ (Projeksiyon)"/>
                                                </ComboBox>
                                                <TextBox x:Name="BrandTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Brand}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
                                                <TextBox x:Name="ModelTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Model}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
                                                <TextBox x:Name="SerialNumberTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Serial}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
</StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBox x:Name="DeviceNameTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_DeviceName}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
                                                <ComboBox x:Name="OwnerComboBox" IsEditable="True" IsTextSearchEnabled="False"
                                                          materialDesign:HintAssist.Hint="{DynamicResource AddForm_Owner}"
                                                          Style="{StaticResource FslComboBox}"
                                                          Margin="0,0,0,20"
                                                          KeyUp="OwnerComboBox_TextChanged" />
                                                <TextBox x:Name="OwnerEmailTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_OwnerEmail}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
                                                <TextBox x:Name="OwnerPhoneTextBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_OwnerPhone}" Style="{StaticResource FslTextBox}" Margin="0,0,0,20"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                    
                                    <Expander Header="{DynamicResource AddForm_TechDetails}" Margin="0,20,0,0">
                                        <StackPanel x:Name="DynamicFieldsPanel" Margin="10"/>
                                    </Expander>

                                    <Expander x:Name="AdvancedSpecsExpander" Header="{DynamicResource AddForm_Advanced}" Margin="0,10,0,0" Visibility="Collapsed">
                                        <StackPanel x:Name="AdvancedFieldsPanel" Margin="10"/>
                                    </Expander>

                                    <Expander Header="{DynamicResource AddForm_Finance}" Margin="0,10,0,25">
                                        <Grid Margin="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox x:Name="StatusComboBox" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Status}" Style="{StaticResource FslComboBox}" Margin="0,0,10,20">
                                                <ComboBoxItem Content="{DynamicResource Status_Active}" Tag="Aktif" IsSelected="True"/>
                                                <ComboBoxItem Content="{DynamicResource Status_Inactive}" Tag="Pasif"/>
                                                <ComboBoxItem Content="{DynamicResource Status_Faulty}" Tag="Arızalı"/>
                                            </ComboBox>
                                            <DatePicker x:Name="ManufactureDatePicker" Grid.Column="1" materialDesign:HintAssist.Hint="{DynamicResource AddForm_ManufactureDate}" Style="{StaticResource FslDatePicker}" Margin="0,0,10,20"/>
                                            <DatePicker x:Name="PurchaseDatePicker" Grid.Column="2" materialDesign:HintAssist.Hint="{DynamicResource AddForm_PurchaseDate}" Style="{StaticResource FslDatePicker}" Margin="0,0,0,20"/>
                                            <TextBox x:Name="CostTextBox" Grid.Row="1" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Cost}" Style="{StaticResource FslTextBox}" Margin="0,0,10,0"/>
                                            <TextBox x:Name="PeriodTextBox" Grid.Row="1" Grid.Column="1" materialDesign:HintAssist.Hint="{DynamicResource AddForm_Period}" Style="{StaticResource FslTextBox}" Margin="0,0,10,0" PreviewTextInput="NumberValidationTextBox"/>
                                            <TextBox x:Name="WarrantyPeriodTextBox" Grid.Row="1" Grid.Column="2" Text="24" materialDesign:HintAssist.Hint="{DynamicResource AddForm_WarrantyPeriod}" Style="{StaticResource FslTextBox}" Margin="0,0,0,0" PreviewTextInput="NumberValidationTextBox"/>
                                            <DatePicker x:Name="LastMaintenanceDatePicker" Visibility="Collapsed"/>
                                        </Grid>
                                    </Expander>

                                    <Button x:Name="SaveButton" Style="{StaticResource FslPrimaryButton}" Height="50" Click="SaveButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,10,0"/>
                                            <TextBlock Text="{DynamicResource AddForm_Save}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </materialDesign:Card>
                        </ScrollViewer>
                    </materialDesign:TransitioningContent>

                    <!-- 4. GÖRÜNÜM: BAKIM TAKVİMİ -->
                    <materialDesign:TransitioningContent x:Name="MaintenanceTransitioner" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <materialDesign:Card Padding="0">
                                <DataGrid x:Name="MaintenanceDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MouseDoubleClick="DevicesDataGrid_MouseDoubleClick" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{DynamicResource Col_Id}" Binding="{Binding Id}" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_BrandModel}" Binding="{Binding FullName}" Width="*"/>
                                        <DataGridTextColumn Header="{DynamicResource Col_LastMaint}" Binding="{Binding LastMaintenanceDate, Converter={StaticResource DateConverter}}" Width="*"/>
                                        <DataGridTemplateColumn Header="{DynamicResource Col_NextMaint}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding NextMaintenanceDate, Converter={StaticResource DateConverter}}" Foreground="{DynamicResource FslTextPrimary}" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </materialDesign:Card>
                        </Grid>
                    </materialDesign:TransitioningContent>

                    <!-- 5. GÖRÜNÜM: MÜŞTERİLER -->
                    <materialDesign:TransitioningContent x:Name="CustomersTransitioner" Visibility="Collapsed">
                        <Grid x:Name="CustomersView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <materialDesign:Card Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomersSearchBox" materialDesign:HintAssist.Hint="{DynamicResource Customers_Search}" Style="{StaticResource FslTextBox}" Margin="0,0,20,0" TextChanged="CustomersSearchBox_TextChanged"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource Customers_Title}" VerticalAlignment="Center" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{DynamicResource FslTextSecondary}"/>
                                </Grid>
                            </materialDesign:Card>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <materialDesign:Card Padding="0" Margin="0,0,15,0">
                                    <DataGrid x:Name="CustomersDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionChanged="CustomersDataGrid_SelectionChanged" BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource Customers_Col_Name}" Binding="{Binding Name}" Width="*" MinWidth="180" FontWeight="Bold"/>
                                            <DataGridTextColumn Header="{DynamicResource Customers_Col_TotalDevices}" Binding="{Binding TotalDevices}" Width="90"/>
                                            <DataGridTextColumn Header="{DynamicResource Customers_Col_TotalCost}" Binding="{Binding TotalCostDisplay}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="1" Padding="0">
                                    <DataGrid x:Name="CustomerDevicesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0" MouseDoubleClick="DevicesDataGrid_MouseDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource Col_Id}" Binding="{Binding Id}" FontWeight="Bold"/>
                                            <DataGridTextColumn Header="{DynamicResource Col_Type}" Binding="{Binding Type}"/>
                                            <DataGridTextColumn Header="{DynamicResource Col_BrandModel}" Binding="{Binding FullName}" Width="*"/>
                                            <DataGridTextColumn Header="{DynamicResource Col_Status}" Binding="{Binding Status, Converter={StaticResource StatusDisplayConverter}}" Width="120"/>
                                            <DataGridTextColumn Header="{DynamicResource AddForm_Cost}" Binding="{Binding Cost}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </materialDesign:Card>
                            </Grid>
                        </Grid>
                    </materialDesign:TransitioningContent>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>